@page
@model SmartHome.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Smart Home Agent";
}

<div class="smart-home-container">
    <div class="house-panel">
        <h2>🏠 Floor Plan</h2>
        <svg viewBox="0 0 420 280" class="house-blueprint" xmlns="http://www.w3.org/2000/svg">
            <!-- House outline -->
            <rect x="5" y="5" width="410" height="270" rx="6" fill="none" stroke="#4fc3f7" stroke-width="2"/>
            
            <!-- Kitchen (top-left) -->
            <rect x="12" y="12" width="195" height="125" rx="3" fill="rgba(79,195,247,0.05)" stroke="#4fc3f7" stroke-width="1"/>
            <text x="110" y="32" text-anchor="middle" fill="#b3e5fc" font-size="11" font-family="'Segoe UI',sans-serif" font-weight="500">Kitchen</text>
            <circle cx="110" cy="68" r="14" class="light-bulb @(Model.HouseState.Rooms["Kitchen"] ? "light-on" : "light-off")"/>
            <text x="110" y="73" text-anchor="middle" fill="#1a237e" font-size="10" font-weight="bold">💡</text>
            <text x="110" y="100" text-anchor="middle" fill="@(Model.HouseState.Rooms["Kitchen"] ? "#ffd600" : "#546e7a")" font-size="10" font-family="monospace" font-weight="600">@(Model.HouseState.Rooms["Kitchen"] ? "ON" : "OFF")</text>
            
            <!-- Living Room (top-right) -->
            <rect x="213" y="12" width="195" height="125" rx="3" fill="rgba(79,195,247,0.05)" stroke="#4fc3f7" stroke-width="1"/>
            <text x="310" y="32" text-anchor="middle" fill="#b3e5fc" font-size="11" font-family="'Segoe UI',sans-serif" font-weight="500">Living Room</text>
            <circle cx="310" cy="68" r="14" class="light-bulb @(Model.HouseState.Rooms["Living Room"] ? "light-on" : "light-off")"/>
            <text x="310" y="73" text-anchor="middle" fill="#1a237e" font-size="10" font-weight="bold">💡</text>
            <text x="310" y="100" text-anchor="middle" fill="@(Model.HouseState.Rooms["Living Room"] ? "#ffd600" : "#546e7a")" font-size="10" font-family="monospace" font-weight="600">@(Model.HouseState.Rooms["Living Room"] ? "ON" : "OFF")</text>
            
            <!-- Bedroom (bottom-left) -->
            <rect x="12" y="143" width="130" height="125" rx="3" fill="rgba(79,195,247,0.05)" stroke="#4fc3f7" stroke-width="1"/>
            <text x="77" y="163" text-anchor="middle" fill="#b3e5fc" font-size="11" font-family="'Segoe UI',sans-serif" font-weight="500">Bedroom</text>
            <circle cx="77" cy="200" r="14" class="light-bulb @(Model.HouseState.Rooms["Bedroom"] ? "light-on" : "light-off")"/>
            <text x="77" y="205" text-anchor="middle" fill="#1a237e" font-size="10" font-weight="bold">💡</text>
            <text x="77" y="232" text-anchor="middle" fill="@(Model.HouseState.Rooms["Bedroom"] ? "#ffd600" : "#546e7a")" font-size="10" font-family="monospace" font-weight="600">@(Model.HouseState.Rooms["Bedroom"] ? "ON" : "OFF")</text>
            
            <!-- Bathroom (bottom-center) -->
            <rect x="148" y="143" width="130" height="125" rx="3" fill="rgba(79,195,247,0.05)" stroke="#4fc3f7" stroke-width="1"/>
            <text x="213" y="163" text-anchor="middle" fill="#b3e5fc" font-size="11" font-family="'Segoe UI',sans-serif" font-weight="500">Bathroom</text>
            <circle cx="213" cy="200" r="14" class="light-bulb @(Model.HouseState.Rooms["Bathroom"] ? "light-on" : "light-off")"/>
            <text x="213" y="205" text-anchor="middle" fill="#1a237e" font-size="10" font-weight="bold">💡</text>
            <text x="213" y="232" text-anchor="middle" fill="@(Model.HouseState.Rooms["Bathroom"] ? "#ffd600" : "#546e7a")" font-size="10" font-family="monospace" font-weight="600">@(Model.HouseState.Rooms["Bathroom"] ? "ON" : "OFF")</text>
            
            <!-- Garage (bottom-right) -->
            <rect x="284" y="143" width="124" height="125" rx="3" fill="rgba(79,195,247,0.05)" stroke="#4fc3f7" stroke-width="1"/>
            <text x="346" y="163" text-anchor="middle" fill="#b3e5fc" font-size="11" font-family="'Segoe UI',sans-serif" font-weight="500">Garage</text>
            <circle cx="346" cy="200" r="14" class="light-bulb @(Model.HouseState.Rooms["Garage"] ? "light-on" : "light-off")"/>
            <text x="346" y="205" text-anchor="middle" fill="#1a237e" font-size="10" font-weight="bold">💡</text>
            <text x="346" y="232" text-anchor="middle" fill="@(Model.HouseState.Rooms["Garage"] ? "#ffd600" : "#546e7a")" font-size="10" font-family="monospace" font-weight="600">@(Model.HouseState.Rooms["Garage"] ? "ON" : "OFF")</text>
        </svg>
    </div>

    <div class="chat-panel">
        <h2>💬 Chat with Agent</h2>
        <div class="chat-messages" id="chatMessages">
            @if (!Model.ChatMessages.Any())
            {
                <div class="chat-welcome">
                    <p>Welcome! I'm your smart home assistant. Try commands like:</p>
                    <ul>
                        <li>"Turn on the kitchen light"</li>
                        <li>"What's the status of all lights?"</li>
                        <li>"Turn off the bedroom and garage lights"</li>
                    </ul>
                </div>
            }
            @foreach (var msg in Model.ChatMessages)
            {
                <div class="chat-bubble @(msg.Role == "user" ? "user-bubble" : "assistant-bubble")">
                    <span class="chat-role">@(msg.Role == "user" ? "You" : "🤖 Agent")</span>
                    <p>@msg.Content</p>
                </div>
            }
        </div>
        <form method="post" class="chat-input-form">
            @Html.AntiForgeryToken()
            <textarea name="UserMessage" placeholder="Ask me to control the lights..." rows="2" class="chat-input" required>@Model.UserMessage</textarea>
            <button type="submit" class="chat-send-btn">Send ➤</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var chatBox = document.getElementById('chatMessages');
        if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
    </script>
}
